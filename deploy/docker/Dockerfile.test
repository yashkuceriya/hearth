FROM golang:1.23-alpine AS go-test
RUN apk add --no-cache git
WORKDIR /app/go
COPY go/ .
RUN go mod download && go test ./... -race -count=1

FROM python:3.12-slim AS python-test
WORKDIR /app/python
COPY python/ .
RUN pip install --no-cache-dir -e ".[dev]" && \
    PYTHONPATH=src python -m pytest tests/ -v

FROM ruby:3.3-slim AS ruby-test
RUN apt-get update && apt-get install -y build-essential libpq-dev && rm -rf /var/lib/apt/lists/*
WORKDIR /app/ruby
COPY ruby/ .
RUN bundle install && bundle exec rspec --format documentation
